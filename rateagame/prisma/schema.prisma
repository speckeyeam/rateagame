generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  userId         String           @id @unique
  dateJoined     DateTime
  coins          Int
  token          String           @unique @default(uuid())
  awardsGiven    award[]          @relation("GiverRelation")
  awardsReceived award[]          @relation("ReceiverRelation")
  awardInventory awardInventory[]
  likes          like[]
  report         report[]
  reviews        review[]
  savedGames     saved[]
  viewed         viewed[]
}

model game {
  gameId           String    @unique
  forSale          Boolean   @default(false)
  lastUpdated      DateTime  @default(now())
  reviews          review[]
  IconImageAssetId String?
  Name             String?
  Created          String?
  Description      String?
  visits           Float?
  Price            Int?
  date             DateTime?
  award            award[]
}

