generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  userId         String           @id @unique
  dateJoined     DateTime
  coins          Int
  token          String           @unique @default(uuid())
  awardsGiven    award[]          @relation("GiverRelation")
  awardsReceived award[]          @relation("ReceiverRelation")
  awardInventory awardInventory[]
  likes          like[]
  report         report[]
  reviews        review[]
  savedGames     saved[]
  viewed         viewed[]
}

model game {
  gameId      String   @unique
  forSale     Boolean  @default(false)
  lastUpdated DateTime @default(now())
  reviews     review[]
}

model gamePass {
  gamePassId String   @unique
  reviews    review[]
  gameId     String?
}

model review {
  time       DateTime
  date       String
  reviewId   String    @id @unique
  gameId     String?
  userId     String?
  recommends Boolean
  rating     Int
  gamePassId String?
  assetId    String
  deleted    Boolean   @default(false)
  text       String    @db.VarChar(2000)
  awards     award[]
  likes      like[]
  game       game?     @relation(fields: [gameId], references: [gameId])
  gamePass   gamePass? @relation(fields: [gamePassId], references: [gamePassId])
  user       user?     @relation(fields: [userId], references: [userId])
  viewed     viewed[]

  @@index([gameId], map: "review_gameId_fkey")
  @@index([userId], map: "review_userId_fkey")
  @@index([gamePassId], map: "review_gamePassId_fkey")
}

model like {
  id             String   @id @unique
  value          Boolean  @default(true)
  reviewId       String
  gamePassId     String?
  gameId         String?
  userId         String?
  time           DateTime @default(now())
  recievedUserId String?
  review         review   @relation(fields: [reviewId], references: [reviewId])
  user           user?    @relation(fields: [userId], references: [userId])

  @@index([reviewId], map: "like_reviewId_fkey")
  @@index([userId], map: "like_userId_fkey")
}

model award {
  id             Int      @id @default(autoincrement())
  time           DateTime
  reviewId       String
  awardId        String
  givenUserId    String
  receivedUserId String
  giver          user     @relation("GiverRelation", fields: [givenUserId], references: [userId])
  receiver       user     @relation("ReceiverRelation", fields: [receivedUserId], references: [userId])
  review         review   @relation(fields: [reviewId], references: [reviewId])

  @@index([givenUserId], map: "award_givenUserId_fkey")
  @@index([receivedUserId], map: "award_receivedUserId_fkey")
  @@index([reviewId], map: "award_reviewId_fkey")
}

model awardInventory {
  id      Int     @id @default(autoincrement())
  awardId String
  userId  String?
  user    user?   @relation(fields: [userId], references: [userId])

  @@index([userId], map: "awardInventory_userId_fkey")
}

model saved {
  id         String   @unique
  gameId     String?
  gamePassId String?
  userId     String
  time       DateTime
  date       String
  user       user     @relation(fields: [userId], references: [userId])
  assetId    String?

  @@index([userId], map: "saved_userId_fkey")
}

model report {
  id       Int      @id @default(autoincrement())
  gameId   String
  reviewId String
  time     DateTime
  userId   String
  user     user     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "saved_userId_fkey")
}

model viewed {
  id       Int      @id @default(autoincrement())
  userId   String
  reviewId String
  time     DateTime @default(now())
  review   review   @relation(fields: [reviewId], references: [reviewId])
  user     user     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "viewed_userId_fkey")
  @@index([reviewId], map: "viewed_reviewId_fkey")
}
