generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  userId         String           @id @unique
  dateJoined     DateTime
  coins          Int
  awardsGiven    award[]          @relation("GiverRelation")
  awardsReceived award[]          @relation("ReceiverRelation")
  awardInventory awardInventory[]
  reviews        review[]
  reviewData     reviewData[]
  savedGames     saved[]
  report         report[]
  token          String           @unique @default(uuid())
}

model game {
  gameId   String   @unique
  reviews  review[]
  gamePass Boolean  @default(false)
}

model reviewData {
  reviewId   String   @unique
  time       DateTime
  text       String   @db.VarChar(2000)
  gameId     String
  recommends Boolean
  userId     String?
  id         Int      @id @default(autoincrement())
  awards     award[]
  likes      like[]
  review     review?
  user       user?    @relation(fields: [userId], references: [userId])

  @@index([userId], map: "reviewData_userId_fkey")
}

model review {
  time       DateTime
  reviewId   String     @id
  gameId     String
  userId     String?
  recommends Boolean
  gamePass   Boolean    @default(false)
  game       game       @relation(fields: [gameId], references: [gameId])
  review     reviewData @relation(fields: [reviewId], references: [reviewId])
  user       user?      @relation(fields: [userId], references: [userId])

  @@index([gameId], map: "review_gameId_fkey")
  @@index([userId], map: "review_userId_fkey")
}

model like {
  id           Int        @id @default(autoincrement())
  reviewId     String
  reviewGameId String
  gameId       String
  userId       String
  reviewData   reviewData @relation(fields: [reviewId], references: [reviewId])

  @@index([reviewId], map: "like_reviewId_fkey")
}

model award {
  id             Int        @id @default(autoincrement())
  time           DateTime
  reviewId       String
  awardId        String
  givenUserId    String
  receivedUserId String
  giver          user       @relation("GiverRelation", fields: [givenUserId], references: [userId])
  receiver       user       @relation("ReceiverRelation", fields: [receivedUserId], references: [userId])
  reviewData     reviewData @relation(fields: [reviewId], references: [reviewId])

  @@index([givenUserId], map: "award_givenUserId_fkey")
  @@index([receivedUserId], map: "award_receivedUserId_fkey")
  @@index([reviewId], map: "award_reviewId_fkey")
}

model awardInventory {
  id      Int     @id @default(autoincrement())
  awardId String
  userId  String?
  user    user?   @relation(fields: [userId], references: [userId])

  @@index([userId], map: "awardInventory_userId_fkey")
}

model saved {
  id     Int      @id @default(autoincrement())
  gameId String
  userId String
  time   DateTime
  user   user     @relation(fields: [userId], references: [userId])

  @@index([userId], map: "saved_userId_fkey")
}

model report {
  id       Int      @id @default(autoincrement())
  gameId   String
  reviewId String
  time     DateTime
  user     user     @relation(fields: [userId], references: [userId])
  userId   String

  @@index([userId], map: "saved_userId_fkey")
}
