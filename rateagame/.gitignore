###############################################################################
#  Core runtime artefacts
###############################################################################
# Node & Bun dependency caches
node_modules/
.bun/**                  # Bun transpilation cache
.bundler-cache/
bun.lockb

# Package-manager logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

###############################################################################
#  Build / transpilation output
###############################################################################
dist/
build/
out/
.next/                   # next-like tools
*.tsbuildinfo           # TypeScript incremental info

###############################################################################
#  Tools & framework artefacts
###############################################################################
# Prisma
prisma/*.db              # SQLite dev DB
prisma/*.db-journal
prisma/migrations/*/README.md
*.prisma.migrate.sql     # dry-run migration dumps

# Vitest / Jest / coverage
coverage/
.nyc_output/
*.lcov

###############################################################################
#  Editor & OS noise
###############################################################################
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.eslintcache
.cache/

###############################################################################
#  Environment / secrets
###############################################################################
.env*
!.env.example            # keep a template for collaborators

