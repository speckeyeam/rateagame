{
  "name": "rateagame",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write . && eslint . --fix",
    "build": "bun build --minify --target=bun --outfile=dist/index.js ./src/index.ts",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "hono": "^4.6.18"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^6.2.1"
  }
}